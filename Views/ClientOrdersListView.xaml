<Window x:Class="RestaurantApp.Views.ClientOrdersListView"         
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"         
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"         
        xmlns:vm="clr-namespace:RestaurantApp.ViewModels"         
        Title="Comenzile mele" Height="550" Width="750">
    <Window.DataContext>
        <vm:ClientOrdersListVM />
    </Window.DataContext>
    <StackPanel Margin="10">
        <WrapPanel Margin="0,0,0,10">
            <Button Content="Anuleaza comanda selectata"                     
                    Width="200" Height="30"                     
                    Command="{Binding CancelCommand}"                     
                    CommandParameter="{Binding ElementName=ordersGrid, Path=SelectedItem}"/>
        </WrapPanel>
        <TextBlock Text="{Binding ErrorMessage}"                    
                   Foreground="Red" FontSize="13" Margin="0,5"/>
        <DataGrid Name="ordersGrid"                   
                  ItemsSource="{Binding Orders}"                   
                  AutoGenerateColumns="False" Height="430"                   
                  IsReadOnly="True"                   
                  ScrollViewer.VerticalScrollBarVisibility="Visible">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Cod Comanda"                     
                                    Binding="{Binding OrderCode}" 
                                    Width="150"/>
                <DataGridTextColumn Header="Data Comenzii"                     
                                    Binding="{Binding OrderDate,                         
                                    StringFormat={}{0:dd/MM/yyyy HH:mm}}" 
                                    Width="130"/>
                <DataGridTextColumn Header="Status"                     
                                    Binding="{Binding Status}" 
                                    Width="110"/>
                <DataGridTextColumn Header="Total (lei)"                     
                                    Binding="{Binding TotalCost,                         
                                    StringFormat={}{0:F2}}" 
                                    Width="90"/>
                <DataGridTextColumn Header="Livrare est."                     
                                    Binding="{Binding EstimatedDelivery,                         
                                    StringFormat={}{0:HH:mm}}" 
                                    Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</Window> 
