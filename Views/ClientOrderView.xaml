<Window x:Class="RestaurantApp.Views.ClientOrderView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RestaurantApp.ViewModels"
        xmlns:conv="clr-namespace:RestaurantApp.Converters"
        Title="Plaseaza comanda" Height="600" Width="850">
    <Window.DataContext>
        <vm:ClientOrderVM/>
    </Window.DataContext>
    <Window.Resources>
        <conv:OrderItemConverter x:Key="orderItemConvert"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Preparate disponibile"
                   FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <DataGrid Grid.Row="1" Grid.Column="0"
                  Name="dishesGrid"
                  ItemsSource="{Binding AvailableDishes}"
                  SelectedItem="{Binding SelectedDish}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="0,0,10,0"
                  ScrollViewer.VerticalScrollBarVisibility="Visible">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Preparat"
                    Binding="{Binding Name}" Width="150"/>
                <DataGridTextColumn Header="Categorie"
                    Binding="{Binding CategoryName}" Width="100"/>
                <DataGridTextColumn Header="Cantitate/portie"
                    Binding="{Binding DisplayQuantity}" Width="110"/>
                <DataGridTextColumn Header="Pret (lei)"
                    Binding="{Binding Price, StringFormat={}{0:F2}}"
                    Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <WrapPanel Grid.Row="2" Grid.Column="0" Margin="0,8,10,8">
            <Label Content="Cantitate:" Width="80" FontSize="14"/>
            <TextBox Name="txtQty" Width="60" FontSize="14"
                     Text="{Binding Quantity,
                         UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Adauga in cos"
                    Width="130" Height="30"
                    Margin="10,0,0,0" FontSize="13"
                    Command="{Binding AddToCartCommand}"/>
        </WrapPanel>

        <TextBlock Grid.Row="0" Grid.Column="1"
                   Text="Cosul tau"
                   FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <DataGrid Grid.Row="1" Grid.Column="1"
                  Name="cartGrid"
                  ItemsSource="{Binding CartItems}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  ScrollViewer.VerticalScrollBarVisibility="Visible">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Produs"
                    Binding="{Binding ProductName}" Width="150"/>
                <DataGridTextColumn Header="Cant."
                    Binding="{Binding Quantity}" Width="50"/>
                <DataGridTextColumn Header="Pret unitar"
                    Binding="{Binding UnitPrice,
                        StringFormat={}{0:F2}}" Width="80"/>
                <DataGridTextColumn Header="Total"
                    Binding="{Binding LineTotal,
                        StringFormat={}{0:F2}}" Width="80"/>
                <DataGridTemplateColumn Header="Sterge" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="X"
                                    Width="40" Height="22"
                                    Foreground="Red"
                                    Command="{Binding DataContext.RemoveFromCartCommand,
                                        RelativeSource={RelativeSource
                                            AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,8,0,0">
            <TextBlock FontSize="15" FontWeight="Bold">
                <Run Text="Total estimat: "/>
                <Run Text="{Binding TotalCost, StringFormat={}{0:F2}}"/>
                <Run Text=" lei"/>
            </TextBlock>
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red" FontSize="13"
                       TextWrapping="Wrap" Margin="0,4,0,4"/>
            <TextBlock Text="{Binding SuccessMessage}"
                       Foreground="Green" FontSize="13"
                       TextWrapping="Wrap" Margin="0,4,0,4"/>
        </StackPanel>

        <Button Grid.Row="3" Grid.Column="1"
                Content="Plaseaza Comanda"
                Height="38" FontSize="15"
                FontWeight="Bold"
                Background="#FF27AE60"
                Foreground="White"
                Margin="0,8,0,0"
                Command="{Binding PlaceOrderCommand}"/>
    </Grid>
</Window>
