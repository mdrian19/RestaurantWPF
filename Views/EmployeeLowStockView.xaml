<Window x:Class="RestaurantApp.Views.EmployeeLowStockView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RestaurantApp.ViewModels"
        Title="Preparate cu stoc redus" Height="420" Width="500">
    <Window.DataContext>
        <vm:EmployeeLowStockVM/>
    </Window.DataContext>

    <StackPanel Margin="15">
        <WrapPanel Margin="0,0,0,12">
            <TextBlock FontSize="14">
                <Run Text="Preparate cu stoc mai mic sau egal decat "/>
                <Run Text="{Binding Threshold, Mode=OneWay}"
                     FontWeight="Bold" Foreground="#FFE74C3C"/>
                <Run Text=" buc"/>
            </TextBlock>
            <Button Content="Reimprospateaza"
                    Width="130" Height="28"
                    Margin="20,0,0,0"
                    Command="{Binding RefreshCommand}"/>
        </WrapPanel>

        <DataGrid ItemsSource="{Binding LowStockDishes}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True" Height="320"
                  ScrollViewer.VerticalScrollBarVisibility="Visible">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Denumire Preparat"
                    Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Stoc (buc)"
                    Binding="{Binding TotalQuantity, StringFormat={}{0:0}}"
                    Width="110"/>
            </DataGrid.Columns>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding TotalQuantity}"
                                     Value="0">
                            <Setter Property="Background"
                                    Value="#FFFDE8E8"/>
                            <Setter Property="Foreground"
                                    Value="#FFE74C3C"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>
    </StackPanel>
</Window>

