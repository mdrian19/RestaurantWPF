<Window x:Class="RestaurantApp.Views.EmployeeOrdersView"         
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"         
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"         
        xmlns:vm="clr-namespace:RestaurantApp.ViewModels"         
        Title="Gestionare comenzi" Height="600" Width="900">
    <Window.DataContext>
        <vm:EmployeeOrdersVM/>
    </Window.DataContext>
    <StackPanel Margin="10">
        <CheckBox Content="Afiseaza doar comenzile active"                   
                  IsChecked="{Binding ShowOnlyActive}"                   
                  FontSize="14" Margin="0,0,0,10"/>
        <WrapPanel Margin="0,0,0,10">
            <Label Content="Schimba status:" Width="140" FontSize="14"/>
            <ComboBox Width="200" FontSize="14"                       
                      ItemsSource="{Binding Statuses}"                       
                      SelectedItem="{Binding SelectedStatus}"/>
            <Button Content="Aplica" Width="80" Height="30"                     
                    Margin="10,0,0,0"                     
                    Command="{Binding ChangeStatusCommand}"/>
        </WrapPanel>
        <TextBlock Text="{Binding ErrorMessage}"                    
                   Foreground="Red" FontSize="13" Margin="0,5"/>
        <DataGrid ItemsSource="{Binding Orders}"                   
                  SelectedItem="{Binding SelectedOrder}"                   
                  AutoGenerateColumns="False" Height="400"                   
                  IsReadOnly="True"                   
                  ScrollViewer.VerticalScrollBarVisibility="Visible">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Cod Comanda"                     
                                    Binding="{Binding OrderCode}" 
                                    Width="150"/>
                <DataGridTextColumn Header="Data"                     
                                    Binding="{Binding OrderDate,                         
                                    StringFormat={}{0:dd/MM/yyyy HH:mm}}" 
                                    Width="130"/>
                <DataGridTextColumn Header="Status"                     
                                    Binding="{Binding Status}" 
                                    Width="130"/>
                <DataGridTextColumn Header="Client"                     
                                    Binding="{Binding ClientFullName}" 
                                    Width="130"/>
                <DataGridTextColumn Header="Telefon"                     
                                    Binding="{Binding ClientPhone}" 
                                    Width="110"/>
                <DataGridTextColumn Header="Cost alim. (lei)"                     
                                    Binding="{Binding FoodCost,                         
                                    StringFormat={}{0:F2}}" 
                                    Width="100"/>
                <DataGridTextColumn Header="Transport (lei)"                     
                                    Binding="{Binding DeliveryCost,                         
                                    StringFormat={}{0:F2}}" 
                                    Width="100"/>
                <DataGridTextColumn Header="Total (lei)"                     
                                    Binding="{Binding TotalCost,                         
                                    StringFormat={}{0:F2}}" 
                                    Width="90"/>
                <DataGridTextColumn Header="Livrare estimata"                     
                                    Binding="{Binding EstimatedDelivery,                         
                                    StringFormat={}{0:HH:mm}}" 
                                    Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</Window> 
