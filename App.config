<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<connectionStrings>
		<add name="RestaurantDB"
		connectionString="Data Source=.\SQLEXPRESS;Initial 
Catalog=RestaurantDB;
 Integrated Security=True;Encrypt=false;
TrustServerCertificate=true"
		providerName="System.Data.SqlClient"/>
	</connectionStrings>
	<appSettings>
		<add key="MenuDiscountPercent" value="10"/>
		<add key="LargeOrderDiscountThreshold" value="100"/>
		<add key="OrderDiscountPercent" value="5"/>
		<add key="FrequentOrderCount" value="5"/>
		<add key="FrequentOrderDays" value="30"/>
		<add key="FreeDeliveryThreshold" value="50"/>
		<add key="DeliveryCost" value="10"/>
		<add key="LowStockThreshold" value="1000"/>
	</appSettings>
</configuration>